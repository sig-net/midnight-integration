# Copy to .env and fill in or start with no .env at all: on the local
# stack the integration suite (packages/integration-tests) derives every
# value itself, appends the fakenet hand-off pair to .env, and prints the
# rest to save. See that package's README for the workflow.

# --- Midnight endpoints (signet-contract-deploy's midnight-node-config) ---
# Network (undeployed | preview | preprod | stagenet | mainnet); defaults to
# undeployed. Networks other than undeployed target a deployed network over its public RPC.
# The proof server always stays local (it sees private witness data).
NETWORK_ID=
# Endpoint overrides; default per NETWORK_ID (undeployed = the local docker
# stack in docker-compose.yaml; deployed networks = their public endpoints)
MIDNIGHT_NODE_URL=
MIDNIGHT_NODE_INDEXER_URL=
MIDNIGHT_NODE_INDEXER_WS_URL=
MIDNIGHT_NODE_PROOF_SERVER_URL=

# --- Wallets (one ROOT funds the three role wallets) ---
# ROOT holds the funds and pays out to the role wallets; it does no test work.
# On undeployed it defaults to the genesis mint wallet. On a DEPLOYED network
# it is generated on the first run, which then STOPS at the root preflight and
# prints ROOT's NIGHT address to fund via the faucet (stagenet:
# https://faucet.stagenet.shielded.tools); a rerun funds the roles and proceeds.
ROOT_SEED=
# The three role wallets (hex or mnemonic). Each is generated + persisted here
# on first run and funded from ROOT; set one to reuse it (skips generation):
#   deployer      - deploys the signet + caller contracts
#   invoker       - drives the caller contract's circuits
#   mpc responder - the fakenet responder's fee-paying wallet
DEPLOYER_SEED=
INVOKER_SEED=
MPC_RESPONDER_SEED=
# NIGHT (base units) to move from ROOT into each role wallet that needs
# funding; unset splits ROOT's balance evenly across the wallets that need it.
FUND_CHILD_NIGHT=

# --- Deployed contracts ---
# Set to skip compile + deploy on the next run. The signet address is
# appended to .env by the setup itself (fakenet hand-off); the caller
# address is printed — save it here.
MIDNIGHT_SIGNET_CONTRACT_ADDRESS=
MIDNIGHT_CALLER_CONTRACT_ADDRESS=

# --- MPC / fakenet signer (github.com/sig-net/solana-signet-program) ---
# Root key the fakenet signer holds; the secp256k1 public key derives from it
# (the setup generates + appends/prints both when unset). The MPC signs EVM
# transactions AND the execution attestations with this one secp256k1 key.
MPC_ROOT_KEY=
MPC_SECP256K1_PUBKEY=

# --- Fakenet container (docker compose interpolates these) ---
# Responder image tag. Override to run a locally built image (e.g. a
# work-in-progress responder before its ghcr push): FAKENET_IMAGE=ghcr.io/sig-net/fakenet:use-ecdsa
#FAKENET_IMAGE=ghcr.io/sig-net/fakenet:latest
# EVM endpoint as reachable FROM THE CONTAINER — the responder's config
# needs a reachable endpoint to boot; the tests themselves are EVM-free.
# Defaults to the in-network anvil compose service.
#FAKENET_EVM_RPC_URL=http://evm:8545
# Set to 0 to run the responder yourself (responder development) — the
# setup then leaves the container and .env alone.
#FAKENET_MANAGED=0

# --- Resume (printed by a partial integration run) ---
# Reuse an in-flight request instead of proving a fresh submit.
#CALLER_REQUEST_ID=
