# Copy to .env and fill in. The integration suite
# (packages/integration-tests) prints a ready-to-paste block for the derived
# values on its first run — see that package's README for the workflow.

# --- Midnight endpoints (packages/lib/src/midnight-node-config.ts) ---
# Network (undeployed | preview | preprod | mainnet); defaults to undeployed
NETWORK_ID=
# Endpoint overrides; default to the local docker stack (docker-compose.yaml)
MIDNIGHT_NODE_URL=
MIDNIGHT_NODE_INDEXER_URL=
MIDNIGHT_NODE_INDEXER_WS_URL=
MIDNIGHT_NODE_PROOF_SERVER_URL=

# --- Identities / wallets ---
# Wallet that funds & signs deploys (hex or mnemonic); defaults to the standalone genesis mint wallet
DEPLOYER_SEED=
# Vault deployer identity secret (32-byte hex, sealed into the contract as a
# commitment); optional — falls back to the DEPLOYER_SEED bytes
VAULT_DEPLOYER_SECRET_KEY=
# Wallet the cli / user-side flows spend from; defaults to the genesis mint wallet
USER_SEED=
# User identity secret answering the vault's callerSecretKey witness;
# optional — falls back to the USER_SEED bytes. NOTE: initialize is
# deployer-gated, so keep user and deployer identities equal for the e2e flow.
VAULT_USER_SECRET_KEY=

# --- Deployed contracts (printed by deploy / the integration suite) ---
MIDNIGHT_VAULT_CONTRACT_ADDRESS=
MIDNIGHT_SIGNET_CONTRACT_ADDRESS=

# --- MPC / fakenet signer (github.com/sig-net/solana-signet-program) ---
# Root key the fakenet signer holds; the two public keys derive from it
# (the integration suite generates + prints all three when unset)
MPC_ROOT_KEY=
MPC_SECP256K1_PUBKEY=
MPC_JUBJUB_PK=

# --- Derived EVM accounts (printed by the integration suite) ---
# Funded automatically on the local dev chain (chain id 31337); fund manually
# on Sepolia as described per account below.
# The vault's account (path "vault"); fund with gas ETH for withdrawals
EVM_VAULT_ADDRESS=
# The user's account (path = identity commitment hex); fund with
# >= 0.01 ETH and >= 0.1 of the ERC20 before the deposit flow
EVM_USER_ADDRESS=

# --- EVM ---
# JSON-RPC endpoint of the EVM chain: Sepolia, or the local hardhat node
# (http://127.0.0.1:8545, started with `npm run evm-node:integration-tests`)
EVM_RPC_URL=
# Resolved from the RPC when unset; verified against it when set (loud failure
# on mismatch — the value is sealed into the vault at initialize)
EVM_CHAIN_ID=
# Token the deposit flow moves. Defaults to Sepolia USDC on Sepolia; on the
# local dev chain setup auto-deploys TestUSDC when the address has no code
# and prints the value
ERC20_ADDRESS=

# --- Resume (printed by a partial integration run) ---
# Request ids that let a rerun pick up an in-flight flow instead of creating
# a fresh request; each flow file prints its own on first creation.
#DEPOSIT_REQUEST_ID=
#WITHDRAW_REQUEST_ID=
#FAILURE_REFUND_DEPOSIT_REQUEST_ID=
#FAILURE_REFUND_WITHDRAW_REQUEST_ID=
#DEPOSIT_CLAIMANT_NOT_CALLER_DEPOSIT_REQUEST_ID=
