# Environment variables for the standalone indexer container
# (docker-compose.yaml `indexer` service). Dev defaults for local use only.
# Schema of the indexer 4.4 (ledger-9 / contract-events) line.
#
#   APP__INFRA__NODE__URL                  -> WebSocket URL of the node the indexer follows
#   APP__INFRA__SECRET                     -> hex-encoded 32 bytes encrypting stored sensitive data (required)
#   APP__INFRA__SPO_NODE__URL              -> SPO node endpoint (points at the same dev node here)
#   APP__INFRA__SPO_NODE__BLOCKFROST_ID    -> Blockfrost project id for SPO queries; dummy value, unused on a local dev chain

APP__INFRA__NODE__URL=ws://node:9944
APP__INFRA__SECRET=303132333435363738393031323334353637383930313233343536373839303132
APP__INFRA__SPO_NODE__URL=ws://node:9944
APP__INFRA__SPO_NODE__BLOCKFROST_ID=dummy-not-using-spo
