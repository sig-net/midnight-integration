# Environment variables for the standalone indexer container
# (docker-compose.yaml `indexer` service). Dev defaults for local use only.
#
#   APP__INFRA__NODE__URL                      -> WebSocket URL of the node the indexer follows
#   APP__INFRA__SECRET                         -> hex-encoded 32 bytes encrypting stored sensitive data (the only required setting)
#   APP__INFRA__STORAGE__PASSWORD              -> password for the indexed-data store
#   APP__INFRA__PUB_SUB__PASSWORD              -> password for the pub/sub channel backing GraphQL subscriptions
#   APP__INFRA__LEDGER_STATE_STORAGE__PASSWORD -> password for the ledger-state store

APP__INFRA__NODE__URL=ws://node:9944
APP__INFRA__STORAGE__PASSWORD=indexer
APP__INFRA__PUB_SUB__PASSWORD=indexer
APP__INFRA__LEDGER_STATE_STORAGE__PASSWORD=indexer
APP__INFRA__SECRET=303132333435363738393031323334353637383930313233343536373839303132
