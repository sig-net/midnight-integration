{
  "name": "@midnight-erc20-vault/integration-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Integration tests that drive the vault through @midnight-erc20-vault/cli against a running Midnight stack. Env-gated: skips entirely unless RUN_INTEGRATION_TESTS is set.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "compile:evm": "hardhat compile",
    "test": "vitest run --passWithNoTests",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run --disable-console-intercept --bail 1",
    "test:integration:happy-day-e2e": "yarn test:integration tests/happy-day-e2e.test.ts",
    "test:integration:deposit-withdrawal-failure-refund": "yarn test:integration tests/deposit-withdrawal-failure-refund.test.ts",
    "test:integration:deposit-claimant-not-caller": "yarn test:integration tests/deposit-claimant-not-caller.test.ts"
  },
  "dependencies": {
    "@midnight-erc20-vault/cli": "*",
    "@midnight-erc20-vault/lib": "*",
    "@midnight-erc20-vault/signet-contract": "^0.0.0",
    "@midnight-erc20-vault/signet-midnight": "*",
    "@midnight-erc20-vault/vault-contract": "*",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "5.0.0-beta.3",
    "ethers": "^6.17.0"
  },
  "devDependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^26.1.0",
    "hardhat": "^3.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
