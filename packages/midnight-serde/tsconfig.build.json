{
  // Emit build for npm publishing ONLY. Local dev never uses this: the rest of
  // the monorepo consumes this package as raw TS source (exports -> ./src/index.ts),
  // so the base config stays noEmit. `yarn build` runs the plain typecheck first,
  // then this config to emit ./dist.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rewriteRelativeImportExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  // src only — tests are typechecked by the plain `tsc -p tsconfig.json` pass.
  "include": ["src"]
}
