{
  "name": "@midnight-erc20-vault/vault-contract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The ERC20 vault Compact contract. src/index.ts is the curated export surface — this IS the \"sdk\" face of the package.",
  "exports": {
    ".": "./src/index.ts",
    "./managed/*": "./src/managed/*"
  },
  "scripts": {
    "compile": "COMPACT_PATH=../../node_modules compact compile --skip-zk src/erc20-vault.compact src/managed",
    "compile:zk": "COMPACT_PATH=../../node_modules compact compile src/erc20-vault.compact src/managed",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "deploy": "tsx deploy.ts"
  },
  "dependencies": {
    "@midnight-erc20-vault/deploy": "*",
    "@midnight-erc20-vault/signet-midnight": "*"
  },
  "devDependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.16.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
