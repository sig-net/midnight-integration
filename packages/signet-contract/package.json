{
  "name": "@midnight-erc20-vault/signet-contract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The central signet Compact contract on Midnight: the MPC posts signature responses (unauthenticated counted log, verified off-chain) and remote execution responses (Schnorr attestations, verified in-circuit at post time) here; clients poll it. src/index.ts is the curated export surface.",
  "exports": {
    ".": "./src/index.ts",
    "./managed/*": "./src/managed/*"
  },
  "scripts": {
    "compile": "COMPACT_PATH=../../node_modules compact compile --skip-zk src/signet-contract.compact src/managed",
    "compile:zk": "COMPACT_PATH=../../node_modules compact compile src/signet-contract.compact src/managed",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "deploy": "tsx deploy.ts"
  },
  "dependencies": {
    "@midnight-erc20-vault/lib": "*",
    "@midnight-ntwrk/midnight-js": "5.0.0-beta.3",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "5.0.0-beta.3",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "5.0.0-beta.3",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "5.0.0-beta.3",
    "@sig-net/midnight": "*"
  },
  "devDependencies": {
    "@midnight-ntwrk/compact-runtime": "0.18.0-rc.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
