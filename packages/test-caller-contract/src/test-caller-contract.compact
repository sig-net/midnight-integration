//                                          💡 NOTE 💡
// This contract drives the Signet Contract @sig-net/contract for integration purposes.
// While informative, for better full integration examples (such as an ERC20 cross chain vault example) see
// the Midnight Examples repository at: https://github.com/sig-net/midnight-examples.
//
// =================== Test Caller Contract ================================================================
// This minimal signet caller tests:
// - initialisation: pinning its MPC response key once after deploy
// - submitting a SignBidirectionalEvent signature request with contract-fixed minimal call data
//   (signed, never broadcast) plus real-EVM requests against the SignetEvmTarget Solidity contract
//   (one submit circuit per target method, growing in ABI complexity over time)
// - verification of the MPC's ECDSA-signed respond-bidirectional response of those requests,
//   one verify circuit per respond-schema packed width
// ========================================================================================================
pragma language_version >= 0.25;

import CompactStandardLibrary;

import "@sig-net/midnight/src/Signet";

// Ledger layout: field numbers are declaration order and stay fixed.
// signBidirectionalEventMap deliberately sits at field 4, after a List that
// grows with each request, so the tests prove the MPC locates it via the
// field position named in the notification.

// field 0: log of every submitted request id, newest first.
export ledger requestLog: List<Bytes<32>>;

// field 1: request counter keeping identical submits distinct.
export ledger signetRequestNonce: Counter;

// field 2: the MPC response key for this contract, pinned by initialise().
export ledger mpcResponseKey: Secp256k1Point;

// field 3: the central signet contract, sealed at deploy; submitSignatureRequest
// cross-contract-calls it to register the request notification the MPC polls.
sealed ledger signetSigner: SignetSigner;

// field 4: the request map the MPC reads requests back from. Sized for EVM
// Type 2 transactions with <1 calldata word, 0 access-list entries,
// 0 storage keys> and the exact-width 34-byte single-bool schema. Shared by
// every request of that shape: submitSignatureRequest and
// submitIsEvenRequest. Schemas are EXACT-length by protocol convention
// (never NUL-padded: the MPC's raw reader recovers the width from the
// stored bytes, and trailing zeros would be trimmed), so a request with a
// different schema length needs its own map: see field 7.
export ledger signBidirectionalEventMap: SignBidirectionalEventMap<EVMType2TxParams<1, 0, 0>, 34, 34>;

// field 5: identity commitment of the deployer; gates initialise().
sealed ledger deployer: Bytes<32>;

// field 6: whether initialise has run (0 = no, 1 = yes).
export ledger initialised: Counter;

// field 7: the request map for the 69-byte bool+uint256 schema
// (submitCheckAndDoubleRequest). One map per schema WIDTH is the growth
// pattern: the notification names each map's field position, so the MPC
// locates whichever map a request lives in. New fields append AFTER this
// one, existing positions stay fixed.
export ledger signBidirectionalEventMap69: SignBidirectionalEventMap<EVMType2TxParams<1, 0, 0>, 69, 69>;

witness deployerSecretKey(): Bytes<32>;

// Exported so deploy tooling and tests can compute the commitment.
export pure circuit deployerCommitment(sk: Bytes<32>): Bytes<32> {
  return persistentHash<Vector<2, Bytes<32>>>([pad(32, "signet-caller:deployer:"), sk]);
}

constructor(initialDeployerCommitment: Bytes<32>, signetContract: SignetSigner) {
  deployer = disclose(initialDeployerCommitment);
  signetSigner = disclose(signetContract);
}

// Tests the two-step configuration: the MPC response key can only be derived
// once the contract address exists, so it is pinned here after deploy.
// One-shot and deployer-gated.
export circuit initialise(responseKey: Secp256k1Point): [] {
  assert(
    initialised == 0,
    "Already initialised: the MPC response key is stored"
  );
  assert(
    deployerCommitment(deployerSecretKey()) == deployer,
    "Not the deployer"
  );
  initialised.increment(1);
  mpcResponseKey = disclose(responseKey);
}

// Tests submitting the smallest well-formed signet request. Everything about
// the transaction is a contract-fixed constant (a syntactically valid payload
// to be SIGNED, never broadcast); the caller supplies only the derived
// account's EVM nonce and the MPC key version.
export circuit submitSignatureRequest(
  evmNonce: Uint<64>,
  keyVersion: Uint<8>
): SignetMapKey {
  const calldata = EVMCalldata<1> {
    selector: Bytes [0xca, 0x11, 0xab, 0x1e],
    noWords: 1 as Uint<16>,
    words: [pad(32, "signet-caller:fixed-word")]
  };

  const txParams = EVMType2TxParams<1, 0, 0> {
    to: pad(20, "signet-caller-e2e-to"),
    chainId: 31337 as Uint<64>,
    nonce: evmNonce,
    gasLimit: 100000 as Uint<64>,
    maxFeePerGas: 30000000000 as Uint<128>,       // 30 gwei
    maxPriorityFeePerGas: 1000000000 as Uint<128>, // 1 gwei
    value: 0 as Uint<128>,
    accessListEntryCount: 0,
    accessList: [],
    calldata: some<EVMCalldata<1>>(calldata)
  };

  const schema = "[{\"name\":\"success\",\"type\":\"bool\"}]" as Bytes<34>;
  const requestNonce = signetRequestNonce as Uint<64>;
  const request = constructSignBidirectionalEvent<EVMType2TxParams<1, 0, 0>, 34, 34>(
    kernel.self(),
    requestNonce,
    keyVersion,
    pad(32, "caller-path"),
    MPCSignatureAlgorithm.ecdsa,
    MPCDestination.unused,
    pad(64, ""),
    TxParamType.evmType2,
    txParams,
    pad(32, "eip155:31337"),
    schema,
    schema
  );
  const requestId = disclose(calculateRequestId<EVMType2TxParams<1, 0, 0>, 34, 34>(request));

  assert(!signBidirectionalEventMap.member(requestId), "Request already exists");
  signetRequestNonce.increment(1);
  signBidirectionalEventMap.insert(requestId, disclose(request));
  requestLog.pushFront(requestId as Bytes<32>);

  // Notify the MPC via the signet contract's registry: the second argument is
  // the ledger field position of signBidirectionalEventMap (4, see layout).
  const requestMapKey = signetSigner.signBidirectionalEvent(
    requestId,
    constructSignBidirectionalEventNotificationV1(
      kernel.self(),
      4 as Uint<8>,
    ),
  );

  return requestMapKey;
}

// Real EVM leg, stage 1a: SignetEvmTarget.isEven(uint256) on the local
// anvil. Unlike submitSignatureRequest's payload, this request IS broadcast:
// the e2e funds the derived sender and sends the signed transaction, and
// the MPC observes the execution and attests its output. The selector is
// the first 4 bytes of keccak256("isEven(uint256)"), pinned here and
// lockstep-checked against ethers in the e2e. The respond schema is the
// same exact-width single bool as submitSignatureRequest's, so the request
// SHARES the field-4 map and its responses verify via verifyResponse
// (packed respond payload: 1 byte).
export circuit submitIsEvenRequest(
  evmNonce: Uint<64>,
  keyVersion: Uint<8>,
  to: Bytes<20>,
  argWord: Bytes<32>
): SignetMapKey {
  const calldata = EVMCalldata<1> {
    selector: Bytes [0x2a, 0x2e, 0x13, 0x20],
    noWords: 1 as Uint<16>,
    words: [argWord]
  };

  const txParams = EVMType2TxParams<1, 0, 0> {
    to: to,
    chainId: 31337 as Uint<64>,
    nonce: evmNonce,
    gasLimit: 100000 as Uint<64>,
    maxFeePerGas: 30000000000 as Uint<128>,       // 30 gwei
    maxPriorityFeePerGas: 1000000000 as Uint<128>, // 1 gwei
    value: 0 as Uint<128>,
    accessListEntryCount: 0,
    accessList: [],
    calldata: some<EVMCalldata<1>>(calldata)
  };

  const schema = "[{\"name\":\"success\",\"type\":\"bool\"}]" as Bytes<34>;
  const requestNonce = signetRequestNonce as Uint<64>;
  const request = constructSignBidirectionalEvent<EVMType2TxParams<1, 0, 0>, 34, 34>(
    kernel.self(),
    requestNonce,
    keyVersion,
    pad(32, "caller-path"),
    MPCSignatureAlgorithm.ecdsa,
    MPCDestination.unused,
    pad(64, ""),
    TxParamType.evmType2,
    txParams,
    pad(32, "eip155:31337"),
    schema,
    schema
  );
  const requestId = disclose(calculateRequestId<EVMType2TxParams<1, 0, 0>, 34, 34>(request));

  assert(!signBidirectionalEventMap.member(requestId), "Request already exists");
  signetRequestNonce.increment(1);
  signBidirectionalEventMap.insert(requestId, disclose(request));
  requestLog.pushFront(requestId as Bytes<32>);

  return signetSigner.signBidirectionalEvent(
    requestId,
    constructSignBidirectionalEventNotificationV1(
      kernel.self(),
      4 as Uint<8>,
    ),
  );
}

// Real EVM leg, stage 1b: SignetEvmTarget.checkAndDouble(uint256) on the
// local anvil, also broadcast by the e2e. The selector is the first 4 bytes
// of keccak256("checkAndDouble(uint256)"), pinned here and lockstep-checked
// against ethers in the e2e. The respond schema is bool + uint256 (69
// bytes, a different exact width than field 4's), so the request lives in
// the field-7 map (named in the notification) and its responses verify via
// verifyCheckAndDoubleResponse (packed respond payload: 33 bytes).
export circuit submitCheckAndDoubleRequest(
  evmNonce: Uint<64>,
  keyVersion: Uint<8>,
  to: Bytes<20>,
  argWord: Bytes<32>
): SignetMapKey {
  const calldata = EVMCalldata<1> {
    selector: Bytes [0xe6, 0xcf, 0x21, 0x87],
    noWords: 1 as Uint<16>,
    words: [argWord]
  };

  const txParams = EVMType2TxParams<1, 0, 0> {
    to: to,
    chainId: 31337 as Uint<64>,
    nonce: evmNonce,
    gasLimit: 100000 as Uint<64>,
    maxFeePerGas: 30000000000 as Uint<128>,       // 30 gwei
    maxPriorityFeePerGas: 1000000000 as Uint<128>, // 1 gwei
    value: 0 as Uint<128>,
    accessListEntryCount: 0,
    accessList: [],
    calldata: some<EVMCalldata<1>>(calldata)
  };

  const schema = "[{\"name\":\"success\",\"type\":\"bool\"},{\"name\":\"amount\",\"type\":\"uint256\"}]" as Bytes<69>;
  const requestNonce = signetRequestNonce as Uint<64>;
  const request = constructSignBidirectionalEvent<EVMType2TxParams<1, 0, 0>, 69, 69>(
    kernel.self(),
    requestNonce,
    keyVersion,
    pad(32, "caller-path"),
    MPCSignatureAlgorithm.ecdsa,
    MPCDestination.unused,
    pad(64, ""),
    TxParamType.evmType2,
    txParams,
    pad(32, "eip155:31337"),
    schema,
    schema
  );
  const requestId = disclose(calculateRequestId<EVMType2TxParams<1, 0, 0>, 69, 69>(request));

  assert(!signBidirectionalEventMap69.member(requestId), "Request already exists");
  signetRequestNonce.increment(1);
  signBidirectionalEventMap69.insert(requestId, disclose(request));
  requestLog.pushFront(requestId as Bytes<32>);

  return signetSigner.signBidirectionalEvent(
    requestId,
    constructSignBidirectionalEventNotificationV1(
      kernel.self(),
      7 as Uint<8>,
    ),
  );
}

// Tests in-circuit verification of the MPC's ECDSA-signed
// respond-bidirectional response: the attestation over (requestId, output)
// must verify against the pinned response key, and the request is consumed
// so it cannot be verified twice. The output width is the client contract's
// own declaration: the single-bool respond schema (submitSignatureRequest
// and submitIsEvenRequest) packs to exactly 1 byte (no padding: the digest
// hashes the output at its exact length).
export circuit verifyResponse(
  requestId: RequestId,
  respondBidirectionalEvent: RespondBidirectionalEvent,
  serializedOutput: Bytes<1>
): [] {
  const disclosedRequestId = disclose(requestId);

  assert(
    initialised != 0,
    "Not initialised: no MPC response key stored"
  );

  assert(
    verifyRespondBidirectionalEvent<1>(
      disclosedRequestId,
      serializedOutput,
      respondBidirectionalEvent,
      mpcResponseKey
    ),
    "Invalid attestation signature"
  );

  assert(signBidirectionalEventMap.member(disclosedRequestId), "Request not found");
  signBidirectionalEventMap.remove(disclosedRequestId);
}

// Same in-circuit verification as verifyResponse but for the checkAndDouble
// respond schema (bool + uint256), whose packed respond payload is exactly
// 33 bytes: a 1-byte bool followed by a 32-byte little-endian Field. The
// request is consumed from the field-7 map those requests live in.
// Duplicated rather than factored: contract-level circuits cannot be
// generic over the output width.
export circuit verifyCheckAndDoubleResponse(
  requestId: RequestId,
  respondBidirectionalEvent: RespondBidirectionalEvent,
  serializedOutput: Bytes<33>
): [] {
  const disclosedRequestId = disclose(requestId);

  assert(
    initialised != 0,
    "Not initialised: no MPC response key stored"
  );

  assert(
    verifyRespondBidirectionalEvent<33>(
      disclosedRequestId,
      serializedOutput,
      respondBidirectionalEvent,
      mpcResponseKey
    ),
    "Invalid attestation signature"
  );

  assert(signBidirectionalEventMap69.member(disclosedRequestId), "Request not found");
  signBidirectionalEventMap69.remove(disclosedRequestId);
}
