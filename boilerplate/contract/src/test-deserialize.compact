pragma language_version >= 0.22;

import CompactStandardLibrary;

// Test contract: verifies Compact can read all Midnight serialization types
// from a Bytes<4096> buffer using slice<32> + as Field.
//
// === testDeserialize layout ===
//   offset 0:   bool        → 32-byte LE (1 = true, 0 = false)
//   offset 32:  uint256     → 32-byte LE
//   offset 64:  address     → 32-byte LE (20-byte value in 32 bytes)
//   offset 96:  uint128     → 32-byte LE
//   offset 128: string      → 32-byte LE length + 128-byte payload
//   offset 288: uint256[]   → 32-byte LE count + 3×32-byte LE elements (maxItems=3)
//   offset 416: bytes32     → 32 raw bytes (NOT LE-encoded as integer)
//   offset 448: bytes       → 32-byte LE length + 64-byte raw payload
//
// === testMultiReturn layout (simulates multiple EVM return values) ===
//   offset 0:   bool        → 32-byte LE
//   offset 32:  uint256     → 32-byte LE
//   offset 64:  address     → 32-byte LE

// ---- testDeserialize ledger fields ----
export ledger resultBool: Bytes<32>;
export ledger resultUint256: Bytes<32>;
export ledger resultAddress: Bytes<32>;
export ledger resultUint128: Bytes<32>;
export ledger resultStrLen: Bytes<32>;
export ledger resultStrData: Bytes<128>;
export ledger resultArrCount: Bytes<32>;
export ledger resultArrElem0: Bytes<32>;
export ledger resultArrElem1: Bytes<32>;
export ledger resultArrElem2: Bytes<32>;
export ledger resultBytes32: Bytes<32>;
export ledger resultDynBytesLen: Bytes<32>;
export ledger resultDynBytesData: Bytes<64>;

// ---- testMultiReturn ledger fields ----
export ledger multiBool: Bytes<32>;
export ledger multiUint256: Bytes<32>;
export ledger multiAddress: Bytes<32>;

export circuit testDeserialize(data: Bytes<4096>): [] {
  // bool at offset 0
  resultBool = disclose(slice<32>(data, 0));
  const boolVal = slice<32>(data, 0) as Field;
  assert(boolVal == 0 || boolVal == 1, "bool must be 0 or 1");

  // uint256 at offset 32
  resultUint256 = disclose(slice<32>(data, 32));

  // address at offset 64
  resultAddress = disclose(slice<32>(data, 64));

  // uint128 at offset 96
  resultUint128 = disclose(slice<32>(data, 96));

  // string at offset 128: 32-byte LE length + 128-byte payload
  resultStrLen = disclose(slice<32>(data, 128));
  resultStrData = disclose(slice<128>(data, 160));
  const strLen = slice<32>(data, 128) as Field;

  // uint256[] at offset 288: 32-byte LE count + 3×32-byte elements
  resultArrCount = disclose(slice<32>(data, 288));
  resultArrElem0 = disclose(slice<32>(data, 320));
  resultArrElem1 = disclose(slice<32>(data, 352));
  resultArrElem2 = disclose(slice<32>(data, 384));
  const arrCount = slice<32>(data, 288) as Field;

  // bytes32 at offset 416: raw 32 bytes
  resultBytes32 = disclose(slice<32>(data, 416));

  // dynamic bytes at offset 448: 32-byte LE length + 64-byte payload
  resultDynBytesLen = disclose(slice<32>(data, 448));
  resultDynBytesData = disclose(slice<64>(data, 480));
  const dynBytesLen = slice<32>(data, 448) as Field;
}

// Simulates reading a multi-value EVM return: (bool, uint256, address)
// This is what a real claim() circuit would do with respondSchema
// [{ type: "bool" }, { type: "uint256" }, { type: "address" }]
export circuit testMultiReturn(data: Bytes<4096>): [] {
  // bool at offset 0
  multiBool = disclose(slice<32>(data, 0));
  const success = slice<32>(data, 0) as Field;
  assert(success == 0 || success == 1, "bool must be 0 or 1");

  // uint256 at offset 32
  multiUint256 = disclose(slice<32>(data, 32));
  const amount = slice<32>(data, 32) as Field;

  // address at offset 64
  multiAddress = disclose(slice<32>(data, 64));
  const addr = slice<32>(data, 64) as Field;
}
