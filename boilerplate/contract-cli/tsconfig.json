{
  "include": ["src/api.ts", "src/common-types.ts", "src/config.ts", "src/index.ts", "src/contract-analyzer.ts", "src/logger-utils.ts"],
  "exclude": ["src/test/**/*.ts", "src/cli.ts", "src/dynamic-cli-generator.ts", "src/simple-enhanced-cli.ts", "src/enhanced-api.ts", "src/auto-generate-cli.ts", "src/test-analyzer.ts"],
  "compilerOptions": {
    // "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "lib": ["ESNext"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strict": true,
    "isolatedModules": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@contract/*": ["../../contract/src/*"]
    }
  }
}
