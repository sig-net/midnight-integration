{
  "name": "midnight-erc20-vault",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Demonstrates sig-net cross-chain interactions from Midnight: an ERC20 vault driven by MPC-signed EVM transactions. Run `npm run compile` once before `build`/`test` \u2014 the contract packages and signet-midnight typecheck against the generated managed/ output.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "compile": "npm run compile --workspaces --if-present",
    "compile:zk": "npm run compile:zk --workspaces --if-present",
    "compile:vault-contract": "npm run compile -w @midnight-erc20-vault/vault-contract",
    "compile:vault-contract:zk": "npm run compile:zk -w @midnight-erc20-vault/vault-contract",
    "compile:signet-midnight": "npm run compile -w @midnight-erc20-vault/signet-midnight",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration-tests": "npm run test:integration -w @midnight-erc20-vault/integration-tests",
    "test:integration-tests:happy-day-e2e": "npm run test:integration:happy-day-e2e -w @midnight-erc20-vault/integration-tests",
    "deploy:vault-contract": "npm run deploy -w @midnight-erc20-vault/vault-contract",
    "cli": "npm run cli -w @midnight-erc20-vault/cli --",
    "compile:signet-contract": "npm run compile -w @midnight-erc20-vault/signet-contract",
    "compile:signet-contract:zk": "npm run compile:zk -w @midnight-erc20-vault/signet-contract",
    "deploy:signet-contract": "npm run deploy -w @midnight-erc20-vault/signet-contract"
  },
  "overrides": {
    "@midnightntwrk/ledger-v9": "1.0.0-rc.3",
    "@midnightntwrk/onchain-runtime-v4": "4.0.0-rc.2",
    "@midnightntwrk/wallet-sdk-address-format": "4.0.0-beta.2"
  }
}
